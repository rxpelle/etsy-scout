# Etsy Scout Configuration
# Copy this file to .env and fill in your values

# Database path (relative to project root, or absolute)
DB_PATH=data/etsy_scout.db

# Etsy API key (optional - for enhanced data)
# Get one at https://www.etsy.com/developers/
ETSY_API_KEY=

# Proxy URL (optional - for avoiding rate limits)
# Example: http://user:pass@proxy.example.com:8080
PROXY_URL=

# Rate limits (seconds between requests)
AUTOCOMPLETE_RATE_LIMIT=0.5
LISTING_SCRAPE_RATE_LIMIT=2.0
SEARCH_PROBE_RATE_LIMIT=2.0

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
